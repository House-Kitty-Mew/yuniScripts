{
  "script_id": "SERVICES/datagram-engine",
  "version": "1.0.0",
  "include_patterns": [
    "*.py",
    "*.json",
    "*.md",
    "*.info",
    "*.txt",
    "*.ini",
    "*.cfg"
  ],
  "exclude_patterns": [
    "__pycache__",
    "*.pyc",
    ".git",
    "venv",
    ".venv",
    "__pycache__/*",
    "*.egg-info",
    ".gitignore",
    ".DS_Store"
  ],
  "include_databases": false,
  "include_venv": false,
  "include_configs": false,
  "config_sources": [],
  "packaging": {
    "compress": false,
    "hash_algorithm": "SHA256",
    "datagram_version": "1.0.0"
  }
}